// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Role {
  id        Int      @id @default(autoincrement())
  name      String   @unique @db.VarChar(50)
  createdAt DateTime @default(now()) @map("created_at")
  users     User[]

  @@map("roles")
}

model Society {
  id                Int                      @id @default(autoincrement())
  name              String                   @db.VarChar(255)
  type              String                   @db.VarChar(50) // apartment / office
  source            String                   @default("MANUAL") @db.VarChar(20) // MANUAL / SELF_REGISTERED
  address           String?                  @db.VarChar(500)
  city              String?                  @db.VarChar(100)
  state             String?                  @db.VarChar(100)
  pincode           String?                  @db.VarChar(10)
  razorpayKey       String?                  @map("razorpay_key") @db.VarChar(255) // Razorpay key for society maintenance account
  subscriptionId    Int?                     @map("subscription_id")
  status            String                   @default("active") @db.VarChar(20) // active / expired
  createdAt         DateTime                 @default(now()) @map("created_at")
  updatedAt         DateTime                 @updatedAt @map("updated_at")
  users             User[]
  subscriptions     Subscription[]
  payments          Payment[]
  invoices          Invoice[]
  gates             Gate[]
  visitorLogs       VisitorLog[]
  units             Unit[]
  preApprovedGuests PreApprovedGuest[]
  auditLogs         AuditLog[]
  rules             Rule[]
  ruleViolations    RuleViolation[]
  notices           Notice[]
  emergencyRequests EmergencyRequest[]

  // Maintenance Module
  maintenancePlans     SocietyMaintenancePlan[]
  tempMaintenanceBills TempMaintenanceBill[]
  maintenanceBills     MaintenanceBill[]

  @@index([status], map: "idx_societies_status")
  @@index([type], map: "idx_societies_type")
  @@index([subscriptionId], map: "idx_societies_subscription_id")
  @@map("societies")
}

model User {
  id                      Int                  @id @default(autoincrement())
  societyId               Int?                 @map("society_id")
  name                    String               @db.VarChar(255)
  mobile                  String               @unique @db.VarChar(20)
  email                   String?              @unique @db.VarChar(255)
  passwordHash            String?              @map("password_hash") @db.VarChar(255)
  roleId                  Int                  @map("role_id")
  status                  String               @default("active") @db.VarChar(20)
  createdAt               DateTime             @default(now()) @map("created_at")
  updatedAt               DateTime             @updatedAt @map("updated_at")
  role                    Role                 @relation(fields: [roleId], references: [id])
  society                 Society?             @relation(fields: [societyId], references: [id])
  refreshTokens           RefreshToken[]
  visitorLogsCreated      VisitorLog[]         @relation("VisitorLogCreatedBy")
  approvals               Approval[]
  unitMembers             UnitMember[]
  preApprovedGuests       PreApprovedGuest[]   @relation("PreApprovedGuestResident")
  auditLogs               AuditLog[]
  rulesCreated            Rule[]
  violations              RuleViolation[]      @relation("Violator")
  reportedViolations      RuleViolation[]      @relation("Reporter")
  noticesCreated          Notice[]
  noticeReads             NoticeRead[]
  emergencyRequestsRaised EmergencyRequest[]
  emergencyResponses      EmergencyResponse[]

  // Maintenance Module
  tempMaintenanceBillsCreated TempMaintenanceBill[]
  maintenanceBillsCreated     MaintenanceBill[]
  maintenancePaymentsMade     MaintenancePayment[]

  // FCM Tokens
  fcmTokens FcmToken[]

  @@index([societyId], map: "idx_users_society_id")
  @@index([roleId], map: "idx_users_role_id")
  @@index([mobile], map: "idx_users_mobile")
  @@index([email], map: "idx_users_email")
  @@index([status], map: "idx_users_status")
  @@map("users")
}

model Otp {
  id        Int      @id @default(autoincrement())
  mobile    String   @db.VarChar(20)
  otpCode   String   @map("otp_code") @db.VarChar(6)
  expiresAt DateTime @map("expires_at")
  verified  Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")

  @@index([mobile], map: "idx_otps_mobile")
  @@index([expiresAt], map: "idx_otps_expires_at")
  @@map("otps")
}

model RefreshToken {
  id        Int      @id @default(autoincrement())
  userId    Int      @map("user_id")
  token     String   @unique @db.VarChar(500)
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId], map: "idx_refresh_tokens_user_id")
  @@index([token], map: "idx_refresh_tokens_token")
  @@index([expiresAt], map: "idx_refresh_tokens_expires_at")
  @@map("refresh_tokens")
}

model SubscriptionPlan {
  id             Int            @id @default(autoincrement())
  code           String?        @unique @db.VarChar(20) // MONTHLY, YEARLY, TRIAL
  name           String         @db.VarChar(50)
  price          Int // Store in smallest unit (₹800 → 800)
  durationMonths Int            @map("duration_months")
  billingCycle   String?        @db.VarChar(20) // MONTHLY, YEARLY
  visitorLimit   Int?           @map("visitor_limit")
  features       Json? // JSONB for features
  isActive       Boolean        @default(true) @map("is_active")
  createdAt      DateTime       @default(now()) @map("created_at")
  subscriptions  Subscription[]

  @@index([isActive], map: "idx_subscription_plans_is_active")
  @@index([code], map: "idx_subscription_plans_code")
  @@map("subscription_plans")
}

model Subscription {
  id         Int              @id @default(autoincrement())
  societyId  Int              @map("society_id")
  planId     Int              @map("plan_id")
  status     String           @db.VarChar(20) // TRIAL / ACTIVE / GRACE / LOCKED / SUSPENDED
  startDate  DateTime         @map("start_date") @db.Date
  expiryDate DateTime?        @map("expiry_date") @db.Date
  graceDays  Int              @default(3) @map("grace_days")
  createdAt  DateTime         @default(now()) @map("created_at")
  society    Society          @relation(fields: [societyId], references: [id], onDelete: Cascade)
  plan       SubscriptionPlan @relation(fields: [planId], references: [id])

  @@unique([societyId], map: "uq_subscriptions_society_id")
  @@index([societyId], map: "idx_subscriptions_society_id")
  @@index([planId], map: "idx_subscriptions_plan_id")
  @@index([status], map: "idx_subscriptions_status")
  @@index([expiryDate], map: "idx_subscriptions_expiry_date")
  @@map("subscriptions")
}

model Payment {
  id            Int       @id @default(autoincrement())
  societyId     Int       @map("society_id")
  amount        Decimal   @db.Decimal(10, 2)
  gateway       String?   @db.VarChar(20)
  paymentMode   String?   @map("payment_mode") @db.VarChar(50)
  transactionId String?   @map("transaction_id") @db.VarChar(100)
  status        String    @db.VarChar(20)
  paidAt        DateTime? @map("paid_at")
  society       Society   @relation(fields: [societyId], references: [id], onDelete: Cascade)
  invoices      Invoice[]

  @@index([societyId], map: "idx_payments_society_id")
  @@index([transactionId], map: "idx_payments_transaction_id")
  @@index([status], map: "idx_payments_status")
  @@index([paidAt], map: "idx_payments_paid_at")
  @@map("payments")
}

model Invoice {
  id        Int      @id @default(autoincrement())
  societyId Int      @map("society_id")
  paymentId Int?     @map("payment_id")
  invoiceNo String   @unique @map("invoice_no") @db.VarChar(50)
  amount    Decimal  @db.Decimal(10, 2)
  createdAt DateTime @default(now()) @map("created_at")
  society   Society  @relation(fields: [societyId], references: [id], onDelete: Cascade)
  payment   Payment? @relation(fields: [paymentId], references: [id], onDelete: SetNull)

  @@index([societyId], map: "idx_invoices_society_id")
  @@index([paymentId], map: "idx_invoices_payment_id")
  @@index([invoiceNo], map: "idx_invoices_invoice_no")
  @@index([createdAt], map: "idx_invoices_created_at")
  @@map("invoices")
}

model Gate {
  id          Int          @id @default(autoincrement())
  societyId   Int          @map("society_id")
  name        String       @db.VarChar(100) // Main Gate, Back Gate
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")
  society     Society      @relation(fields: [societyId], references: [id], onDelete: Cascade)
  visitorLogs VisitorLog[]

  @@index([societyId], map: "idx_gates_society_id")
  @@map("gates")
}

model Visitor {
  id          Int          @id @default(autoincrement())
  name        String       @db.VarChar(255)
  mobile      String       @db.VarChar(20)
  photoBase64 String?      @map("photo_url") @db.Text
  createdAt   DateTime     @default(now()) @map("created_at")
  visitorLogs VisitorLog[]

  @@index([mobile], map: "idx_visitors_mobile")
  @@index([createdAt], map: "idx_visitors_created_at")
  @@map("visitors")
}

model VisitorLog {
  id            Int               @id @default(autoincrement())
  societyId     Int               @map("society_id")
  gateId        Int               @map("gate_id")
  visitorId     Int?              @map("visitor_id")
  unitId        Int?              @map("unit_id")
  flatNo        String?           @map("flat_no") @db.VarChar(50) // Keep for backward compatibility
  purpose       String?           @db.VarChar(500)
  preApprovalId Int?              @map("pre_approval_id")
  entryTime     DateTime?         @map("entry_time")
  exitTime      DateTime?         @map("exit_time")
  status        String            @default("pending") @db.VarChar(20) // pending / approved / rejected / exited
  createdBy     Int               @map("created_by") // security user_id
  createdAt     DateTime          @default(now()) @map("created_at")
  society       Society           @relation(fields: [societyId], references: [id], onDelete: Cascade)
  gate          Gate              @relation(fields: [gateId], references: [id], onDelete: Cascade)
  visitor       Visitor?          @relation(fields: [visitorId], references: [id], onDelete: Cascade)
  unit          Unit?             @relation(fields: [unitId], references: [id], onDelete: SetNull)
  createdByUser User              @relation("VisitorLogCreatedBy", fields: [createdBy], references: [id])
  preApproval   PreApprovedGuest? @relation(fields: [preApprovalId], references: [id], onDelete: SetNull)
  approvals     Approval[]

  @@index([societyId], map: "idx_visitor_logs_society_id")
  @@index([gateId], map: "idx_visitor_logs_gate_id")
  @@index([visitorId], map: "idx_visitor_logs_visitor_id")
  @@index([unitId], map: "idx_visitor_logs_unit_id")
  @@index([createdBy], map: "idx_visitor_logs_created_by")
  @@index([preApprovalId], map: "idx_visitor_logs_pre_approval_id")
  @@index([status], map: "idx_visitor_logs_status")
  @@index([entryTime], map: "idx_visitor_logs_entry_time")
  @@index([exitTime], map: "idx_visitor_logs_exit_time")
  @@index([createdAt], map: "idx_visitor_logs_created_at")
  @@map("visitor_logs")
}

model Approval {
  id           Int        @id @default(autoincrement())
  visitorLogId Int        @map("visitor_log_id")
  residentId   Int        @map("resident_id")
  decision     String     @db.VarChar(20) // approved / rejected
  decisionTime DateTime   @default(now()) @map("decision_time")
  visitorLog   VisitorLog @relation(fields: [visitorLogId], references: [id], onDelete: Cascade)
  resident     User       @relation(fields: [residentId], references: [id])

  @@index([visitorLogId], map: "idx_approvals_visitor_log_id")
  @@index([residentId], map: "idx_approvals_resident_id")
  @@index([decision], map: "idx_approvals_decision")
  @@index([decisionTime], map: "idx_approvals_decision_time")
  @@map("approvals")
}

model Unit {
  id                Int                @id @default(autoincrement())
  societyId         Int                @map("society_id")
  unitNo            String             @map("unit_no") @db.VarChar(20) // A-302 / 201 / HR-01
  unitType          String?            @map("unit_type") @db.VarChar(20) // FLAT / OFFICE / SHOP
  floor             Int?
  block             String?            @db.VarChar(20)
  status            String             @default("ACTIVE") @db.VarChar(20) // ACTIVE / INACTIVE
  createdAt         DateTime           @default(now()) @map("created_at")
  updatedAt         DateTime           @updatedAt @map("updated_at")
  society           Society            @relation(fields: [societyId], references: [id], onDelete: Cascade)
  members           UnitMember[]
  visitorLogs       VisitorLog[]
  preApprovedGuests PreApprovedGuest[]
  ruleViolations    RuleViolation[]

  // Maintenance Module
  tempMaintenanceBills TempMaintenanceBill[]
  maintenanceBills     MaintenanceBill[]
  emergencyRequests EmergencyRequest[]

  @@unique([societyId, unitNo, block], map: "uq_units_society_unit_no_block")
  @@index([societyId], map: "idx_units_society_id")
  @@index([unitNo], map: "idx_units_unit_no")
  @@index([status], map: "idx_units_status")
  @@map("units")
}

model UnitMember {
  id        Int      @id @default(autoincrement())
  unitId    Int      @map("unit_id")
  userId    Int      @map("user_id")
  role      String   @db.VarChar(20) // OWNER / TENANT / EMPLOYEE
  isPrimary Boolean  @default(false) @map("is_primary")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  unit      Unit     @relation(fields: [unitId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([unitId, userId], map: "uq_unit_members_unit_user")
  @@index([unitId], map: "idx_unit_members_unit_id")
  @@index([userId], map: "idx_unit_members_user_id")
  @@index([isPrimary], map: "idx_unit_members_is_primary")
  @@map("unit_members")
}

model PreApprovedGuest {
  id          Int          @id @default(autoincrement())
  societyId   Int          @map("society_id")
  unitId      Int          @map("unit_id")
  residentId  Int          @map("resident_id")
  guestName   String?      @map("guest_name") @db.VarChar(255)
  guestMobile String?      @map("guest_mobile") @db.VarChar(20)
  photoBase64 String?      @map("photo_base64") @db.Text
  accessCode  String       @unique @map("access_code") @db.VarChar(20)
  validFrom   DateTime     @map("valid_from")
  validTill   DateTime     @map("valid_till")
  maxUses     Int          @default(1) @map("max_uses")
  usedCount   Int          @default(0) @map("used_count")
  status      String       @default("ACTIVE") @db.VarChar(20) // ACTIVE / EXPIRED / USED / REVOKED
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")
  society     Society      @relation(fields: [societyId], references: [id], onDelete: Cascade)
  unit        Unit         @relation(fields: [unitId], references: [id], onDelete: Cascade)
  resident    User         @relation("PreApprovedGuestResident", fields: [residentId], references: [id], onDelete: Cascade)
  visitorLogs VisitorLog[]

  @@index([societyId], map: "idx_pre_approved_guests_society_id")
  @@index([unitId], map: "idx_pre_approved_guests_unit_id")
  @@index([residentId], map: "idx_pre_approved_guests_resident_id")
  @@index([accessCode], map: "idx_pre_approved_guests_access_code")
  @@index([status], map: "idx_pre_approved_guests_status")
  @@index([validTill], map: "idx_pre_approved_guests_valid_till")
  @@map("pre_approved_guests")
}

model AuditLog {
  id          Int      @id @default(autoincrement())
  userId      Int?     @map("user_id")
  societyId   Int?     @map("society_id")
  role        String?  @db.VarChar(50)
  action      String   @db.VarChar(100)
  entity      String   @db.VarChar(100)
  entityId    Int?     @map("entity_id")
  description String?  @db.VarChar(500)
  ipAddress   String?  @map("ip_address") @db.VarChar(45)
  userAgent   String?  @map("user_agent") @db.VarChar(500)
  createdAt   DateTime @default(now()) @map("created_at")

  user    User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  society Society? @relation(fields: [societyId], references: [id], onDelete: SetNull)

  @@index([userId], map: "idx_audit_logs_user_id")
  @@index([societyId], map: "idx_audit_logs_society_id")
  @@index([action], map: "idx_audit_logs_action")
  @@index([entity], map: "idx_audit_logs_entity")
  @@index([createdAt], map: "idx_audit_logs_created_at")
  @@index([role], map: "idx_audit_logs_role")
  @@map("audit_logs")
}

model Rule {
  id               Int      @id @default(autoincrement())
  societyId        Int      @map("society_id")
  title            String
  description      String?
  category         String
  priority         String   @default("Medium")
  isActive         Boolean  @default(true)
  violationPenalty String?  @map("violation_penalty")
  createdBy        Int?     @map("created_by")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  society    Society         @relation(fields: [societyId], references: [id])
  creator    User?           @relation(fields: [createdBy], references: [id])
  violations RuleViolation[]

  @@index([societyId], map: "idx_rules_society")
  @@index([category], map: "idx_rules_category")
  @@map("rules")
}

model RuleViolation {
  id               Int      @id @default(autoincrement())
  societyId        Int      @map("society_id")
  ruleId           Int      @map("rule_id")
  violatorUserId   Int?     @map("violator_user_id")
  violatorUnitId   Int?     @map("violator_unit_id")
  reportedByUserId Int      @map("reported_by_user_id")
  description      String?
  proofImage       String?  @map("proof_image")
  status           String   @default("PENDING")
  penaltyAmount    Decimal? @map("penalty_amount") @db.Decimal(10, 2)
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  society  Society @relation(fields: [societyId], references: [id])
  rule     Rule    @relation(fields: [ruleId], references: [id])
  violator User?   @relation("Violator", fields: [violatorUserId], references: [id])
  reporter User    @relation("Reporter", fields: [reportedByUserId], references: [id])
  unit     Unit?   @relation(fields: [violatorUnitId], references: [id])

  @@index([societyId], map: "idx_violations_society")
  @@index([status], map: "idx_violations_status")
  @@map("rule_violations")
}

model Notice {
  id        Int @id @default(autoincrement())
  societyId Int @map("society_id")
  createdBy Int @map("created_by")

  title         String
  description   String?
  attachmentUrl String? @map("attachment_url")

  noticeType String @map("notice_type") // General / Maintenance / Emergency / Event
  priority   String @default("Medium") // High / Medium / Low
  audience   String // All / Owners / Tenants / Security

  startDate DateTime @map("start_date")
  endDate   DateTime @map("end_date")

  isActive Boolean @default(true)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  society Society      @relation(fields: [societyId], references: [id])
  creator User         @relation(fields: [createdBy], references: [id])
  reads   NoticeRead[]

  @@index([societyId], map: "idx_notices_society")
  @@index([noticeType], map: "idx_notices_type")
  @@index([priority], map: "idx_notices_priority")
  @@map("notices")
}

model NoticeRead {
  id       Int      @id @default(autoincrement())
  noticeId Int      @map("notice_id")
  userId   Int      @map("user_id")
  readAt   DateTime @default(now()) @map("read_at")

  notice Notice @relation(fields: [noticeId], references: [id])
  user   User   @relation(fields: [userId], references: [id])

  @@unique([noticeId, userId])
  @@map("notice_reads")
}



model EmergencyRequest {
  id               Int       @id @default(autoincrement())
  societyId        Int       @map("society_id")
  raisedBy         Int       @map("raised_by")
  unitId           Int?      @map("unit_id")
  emergencyType    String    @map("emergency_type") @db.VarChar(50) // Medical / Fire / Theft / Security / Other
  notificationType String    @map("notification_type") @db.VarChar(20) // SIREN / CALL / PUSH / ALL
  description      String?   @db.VarChar(500)
  location         String?   @db.VarChar(255)
  status           String    @default("OPEN") @db.VarChar(20) // OPEN / ACKNOWLEDGED / RESOLVED
  priority         String    @default("HIGH") @db.VarChar(20)
  raisedAt         DateTime  @default(now()) @map("raised_at")
  acknowledgedAt   DateTime? @map("acknowledged_at")
  resolvedAt       DateTime? @map("resolved_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  society   Society             @relation(fields: [societyId], references: [id], onDelete: Cascade)
  user      User                @relation(fields: [raisedBy], references: [id])
  unit      Unit?               @relation(fields: [unitId], references: [id], onDelete: SetNull)
  responses EmergencyResponse[]

  @@index([societyId], map: "idx_emergency_requests_society")
  @@index([status], map: "idx_emergency_requests_status")
  @@map("emergency_requests")
}

model EmergencyResponse {
  id             Int      @id @default(autoincrement())
  emergencyId    Int      @map("emergency_id")
  responderId    Int      @map("responder_id")
  responseAction String   @map("response_action") @db.VarChar(255)
  responseNotes  String?  @map("response_notes") @db.VarChar(500)
  responseTime   DateTime @default(now()) @map("response_time")

  emergency EmergencyRequest @relation(fields: [emergencyId], references: [id], onDelete: Cascade)
  responder User             @relation(fields: [responderId], references: [id])

  @@index([emergencyId], map: "idx_emergency_responses_emergency")
  @@map("emergency_responses")
}

// ═══════════════════════════════════════════════════════════════════════════
// MAINTENANCE MODULE
// ═══════════════════════════════════════════════════════════════════════════

// 1️⃣ Society Maintenance Plan (Defines MONTHLY / YEARLY amount for a society)
model SocietyMaintenancePlan {
  id        Int      @id @default(autoincrement())
  societyId Int      @map("society_id")

  planType  String   @db.VarChar(20) // MONTHLY / YEARLY
  amount    Int                      // amount in ₹
  isActive  Boolean  @default(true)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  society   Society  @relation(fields: [societyId], references: [id])

  @@unique([societyId, planType])
  @@index([societyId])
  @@map("society_maintenance_plans")
}

// 2️⃣ Temp Maintenance Bill (Preview before final generation)
model TempMaintenanceBill {
  id        Int      @id @default(autoincrement())
  societyId Int      @map("society_id")
  unitId    Int      @map("unit_id")

  billCycle String   @db.VarChar(20) // MONTHLY / YEARLY
  period    String   @db.VarChar(20) // 2025-03 / 2025
  amount    Int
  dueDate   DateTime @map("due_date")
  description String? @db.VarChar(500)

  createdBy Int      @map("created_by")
  createdAt DateTime @default(now()) @map("created_at")

  society   Society  @relation(fields: [societyId], references: [id])
  unit      Unit     @relation(fields: [unitId], references: [id])
  admin     User     @relation(fields: [createdBy], references: [id])

  @@index([societyId])
  @@index([unitId])
  @@map("temp_maintenance_bills")
}

// 3️⃣ Maintenance Bill (FINAL BILL - Official payable bill)
model MaintenanceBill {
  id        Int      @id @default(autoincrement())
  societyId Int      @map("society_id")
  unitId    Int      @map("unit_id")

  billCycle String   @db.VarChar(20) // MONTHLY / YEARLY / SPECIAL
  period    String   @db.VarChar(20) // 2025-03 / 2025 / SPECIAL
  amount    Int
  dueDate   DateTime @map("due_date")
  description String? @db.VarChar(500)

  status    String   @default("UNPAID") @db.VarChar(20) // UNPAID / PAID / OVERDUE

  createdBy Int      @map("created_by")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  society   Society  @relation(fields: [societyId], references: [id])
  unit      Unit     @relation(fields: [unitId], references: [id])
  admin     User     @relation(fields: [createdBy], references: [id])
  payments  MaintenancePayment[]

  @@unique([unitId, billCycle, period])
  @@index([societyId])
  @@index([unitId])
  @@index([status])
  @@map("maintenance_bills")
}

// 4️⃣ Maintenance Payment (Tracks money received)
model MaintenancePayment {
  id            Int      @id @default(autoincrement())
  billId        Int      @map("bill_id")
  paidBy        Int      @map("paid_by")

  amount        Int
  paymentMode   String   @db.VarChar(20) // ONLINE / UPI / CASH / CHEQUE

  transactionId String?  @map("transaction_id")
  status        String   @db.VarChar(20) // SUCCESS / FAILED

  paidAt        DateTime @default(now()) @map("paid_at")

  bill          MaintenanceBill @relation(fields: [billId], references: [id])
  resident      User            @relation(fields: [paidBy], references: [id])

  @@index([billId])
  @@index([paidBy])
  @@map("maintenance_payments")
}

// ═══════════════════════════════════════════════════════════════════════════
// FCM (Firebase Cloud Messaging) TOKENS
// ═══════════════════════════════════════════════════════════════════════════

model FcmToken {
  id        Int      @id @default(autoincrement())
  userId    Int      @map("user_id")
  token     String   @unique @db.VarChar(500) // FCM token
  deviceId  String?  @map("device_id") @db.VarChar(255) // Optional device identifier
  platform  String?  @db.VarChar(20) // android / ios
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId], map: "idx_fcm_tokens_user_id")
  @@index([token], map: "idx_fcm_tokens_token")
  @@index([isActive], map: "idx_fcm_tokens_is_active")
  @@index([platform], map: "idx_fcm_tokens_platform")
  @@map("fcm_tokens")
}
